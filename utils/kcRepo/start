#!/bin/sh
set -e

# ==================================================================
# Repo Start Script
# -----------------
# Builds and runs the ./src files in a Docker container
# ==================================================================

# Update the ./config/settings.cfg file with your project's settings
set -a
. ./config/settings.cfg
set +a

# ==================================================================
# SCRIPT BUILD COMMANDS
# ==================================================================

# Determine the script's directory and project root
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(cd -- "$SCRIPT_DIR" && pwd)

dockerComposeCmd="docker compose --project-directory . -f ${PROJECT_ROOT}/config/docker-compose.yml"
dockerComposeServiceName="main"  # We will build the "main" service defined in docker-compose.yml

# Define all your project's build commands in this block.
COMMANDS="
build: Builds the Docker image for the project.
  ${dockerComposeCmd} build ${dockerComposeServiceName}

rebuild: Builds a clean Docker image from scratch.
  ${dockerComposeCmd} build --no-cache ${dockerComposeServiceName}

run: Runs the main application in a detached container.
  ${dockerComposeCmd} up --remove-orphans ${dockerComposeServiceName}

shell: Starts a shell, attaching to the running project container or creating a new one.
  # First, check if the service is already running. We query by SERVICE name.
  CONTAINER_ID=\$(${dockerComposeCmd} ps -q ${dockerComposeServiceName} || true)
  # If CONTAINER_ID is not empty, a container is running. Attach to it.
  if [ -n \"\$CONTAINER_ID\" ]; then
    echo \"==> Found running project container. Attaching shell...\"
    docker exec -it \"\$CONTAINER_ID\" /bin/sh
  else
    echo \"==> No running container found. Starting a new one for a shell session...\"
  # Use 'run' with the --entrypoint flag to start a NEW container with a shell.
    ${dockerComposeCmd} run --rm --entrypoint /bin/sh ${dockerComposeServiceName}
  fi

stop: Stops and removes the running app container.
  ${dockerComposeCmd} down

test: Runs the project's test suite in a clean, temporary container.
   ${dockerComposeCmd} run --rm tester

clean: Stops containers and removes all related data (images, volumes).
  ${dockerComposeCmd} down -v --remove-orphans
"

# Help Text Examples: Define a few common use-cases for your script.
EXAMPLES="
  Build and run the application for the first time:
    ./start build && ./start run
"

# ==================================================================
# SCRIPT ENGINE
# ==================================================================
# You shouldn't need to edit anything below this line.

# Logging
logmsg() {
  local eventType="$1"
  local eventMessage="$2"
  if [ "$VERBOSE_LOGGING" = "true" ]; then
    local timestamp
    timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    printf "%s | %s | [%s] %s\n" "$timestamp" "$PROJECT_NAME" "$eventType" "$eventMessage"
  else
    if [ "$eventType" = "error" ]; then
      printf "[ERROR] %s\n" "$eventMessage" >&2
    else
      printf "==> %s\n" "$eventMessage"
    fi
  fi
  if command -v logger > /dev/null 2>&1; then
    local tag="$PROJECT_NAME/$(basename "$0")"
    local priority="user.info"
    [ "$eventType" = "error" ] && priority="user.error"
    logger -t "$tag" -p "$priority" -- "$eventMessage"
  fi
}

# Help Text
help() {
  printf "Usage: ./%s {command}\n\n" "$(basename "$0")"
  printf "Commands:\n"
  max_width=$(printf "%s\n" "$COMMANDS" | grep -E '^[a-zA-Z0-9_-]+:' | sed 's/:.*$//' | awk '{print length}' | sort -n | tail -1)
  [ "$max_width" -lt 4 ] && max_width=4
  max_width=$((max_width + 2))
  printf "%s\n" "$COMMANDS" | grep -E '^[a-zA-Z0-9_-]+:' | sed -e 's/^\([^:]*\): \(.*\)/\1|\2/' | sort | \
    while IFS='|' read -r cmd desc; do
      printf "  %-*s - %s\n" "$max_width" "$cmd" "$desc"
    done
  printf "  %-*s - %s\n" "$max_width" "help" "Shows this help message."
  if [ -n "$EXAMPLES" ]; then
    printf "\nExamples:\n"
    printf "%s\n" "$EXAMPLES"
  fi
  exit 0
}

# Command Runner
run_command() {
  local cmd_name="$1"
  if [ -z "$cmd_name" ] || [ "$cmd_name" = "help" ]; then
    help
  fi
  local cmd_desc=$(printf "%s" "$COMMANDS" | grep "^$cmd_name:" | sed "s/^$cmd_name: //")
  local cmd_script=$(printf "%s" "$COMMANDS" | sed -n "/^$cmd_name:/,/^[a-zA-Z0-9_-]*:\|^$/{/^$cmd_name:/d; p;}" | sed 's/^[ \t]*//')
  if [ -z "$cmd_script" ]; then
    logmsg error "Command '$cmd_name' is not defined." && help >&2 && exit 1
  fi
  logmsg info "Running command: $cmd_name..."
  [ "$VERBOSE_LOGGING" = "false" ] && [ -n "$cmd_desc" ] && logmsg info "$cmd_desc"
  if sh -c "$cmd_script"; then
    logmsg info "Finished: $cmd_name"
  else
    logmsg error "Command failed: $cmd_name"
    exit 1
  fi
}

# Script Requirements Check
for dep in docker; do
    if ! command -v "$dep" > /dev/null 2>&1; then
        logmsg error "Required command '$dep' is not installed. Please install it to continue."
        exit 1
    fi
done
if ! docker compose version > /dev/null 2>&1; then
    logmsg error "'docker compose' command not found. Please ensure Docker Compose V2 is installed."
    exit 1
fi

# Pass standard variables to Docker Compose
export HOST_UID=$(id -u)
export HOST_GID=$(id -g)

# Script Entrypoint
run_command "$1"